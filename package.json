{
  "name": "pactsafe-ai-monorepo",
  "version": "0.2.0",
  "private": true,
  "description": "PactSafe AI — contract analysis SaaS (Next.js web + FastAPI api).",
  "workspaces": [
    "apps/web",
    "packages/schemas/typescript"
  ],
  "scripts": {
    "api:dev": "cd apps/api && uvicorn app.main:app --reload --port 8000",
    "web:dev": "cd apps/web && npm run dev",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "author": "Thechaoticsportsguy",
  "license": "MIT"
}
