# PactSafe AI — environment variables (server-side ONLY)
# Copy to .env and fill in values. NEVER expose these to the browser.

# --- LLM provider ---
# Which provider to use by default: "ollama" | "anthropic" | "groq"
LLM_PROVIDER=ollama

# Ollama (local, free)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:0.5b

# Anthropic (optional fallback)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-5

# Groq (optional fallback)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

# --- LlamaParse (smart extraction for large PDFs) ---
# When set, large uploads (>5 MB, or any PDF, or any direct-extracted
# corpus > TOKEN_THRESHOLD tokens) are routed through the LlamaParse
# API instead of pdfplumber. Leave blank to disable.
LLAMA_CLOUD_API_KEY=
# Tokens above this threshold trigger the LlamaParse route.
TOKEN_THRESHOLD=120000
# Hard ceiling for any upload, in MB. Rejects earlier than the soft
# MAX_UPLOAD_MB limit so we don't waste LlamaParse credits on garbage.
HARD_MAX_UPLOAD_MB=100

# --- Database ---
# Postgres (used by docker compose)
DATABASE_URL=postgresql+psycopg://pactsafe:pactsafe@postgres:5432/pactsafe
# For local dev without docker, you can use sqlite:
# DATABASE_URL=sqlite:///./pactsafe.db

# --- App ---
API_HOST=0.0.0.0
API_PORT=8000
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=10

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
